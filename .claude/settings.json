{
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "ANTHROPIC_CUSTOM_MODEL_OPTION": "claude-opus-4-6[1M]",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_NAME": "Opus 4.6",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION": "Opus 4.6 (pinned full model ID)"
  },
  "permissions": {
    "allow": [
      "mcp__claude-in-chrome__find",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_pages",
      "Bash(gh search *)",
      "Bash(npm view *)",
      "mcp__claude-in-chrome__get_page_text",
      "Bash(pnpm lint:unused *)",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__take_screenshot",
      "Bash(claude mcp list *)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/.claude/hooks/git-sync-sessionstart.sh",
            "timeout": 20,
            "statusMessage": "リモート同期状態を確認中..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/.claude/hooks/git-sync-stop.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": false
  },
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "language": "Japanese",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "うるとらしんく",
      "少女思考中...",
      "少女祈祷中...",
      "もみじ饅頭でも食べながらまったりお待ちください",
      "豆大福でも食べながらまったりお待ちください"
    ]
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "autoDreamEnabled": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
